# Base path for deploying to a subdirectory (e.g. /artbook-library for GitHub Pages).
# Leave empty or omit for root deployment.
# VITE_BASE_PATH=/artbook-library

# Custom base URL for media assets (videos, images).
# Leave empty to serve from the same origin as the app.
# VITE_MEDIA_BASE_URL=https://cdn.example.com/media
